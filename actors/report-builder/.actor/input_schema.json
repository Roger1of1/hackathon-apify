{
  "title": "Ex-Ditector Report Builder Input",
  "description": "Normally provided automatically via metamorph from the Diff stage.",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "scope_type": {
      "title": "Scope type",
      "type": "string",
      "editor": "select",
      "enum": ["self", "consented", "public_figure", "brand", "safety_evidence"],
      "enumTitles": ["Self", "Consented", "Public figure", "Brand", "Safety evidence"],
      "default": "self"
    },
    "case_id": {
      "title": "Case ID",
      "type": "string",
      "editor": "textfield"
    },
    "case_store_name": {
      "title": "Case KV store name",
      "type": "string",
      "editor": "textfield",
      "default": "ex-ditector-case"
    },
    "checks_per_day": {
      "title": "Checks per day (wellbeing signal for distress_risk_score)",
      "type": "integer",
      "editor": "number",
      "default": 0,
      "minimum": 0,
      "maximum": 100
    }
  },
  "required": ["scope_type"]
}
